-- ==================== ANTI AFK ====================
local antiAFKConnection

local function StartAntiAFK()
    antiAFKRunning = true
    antiAFKTime = 0
    AntiAFKBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)

    antiAFKConnection = RunService.Heartbeat:Connect(function()
        antiAFKTime += 1
        local min = math.floor(antiAFKTime / 60)
        local sec = antiAFKTime % 60
        AntiAFKBtn.Text = string.format("Anti AFK: %02d:%02d", min, sec)
    end)

    spawn(function()
        while antiAFKRunning do
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                local hum = player.Character.Humanoid
                hum:Move(Vector3.new(math.random(-1,1),0,math.random(-1,1)), true)
                if math.random(1,5) == 1 then hum.Jump = true end
            end
            task.wait(math.random(5,12))
        end
    end)
end

local function StopAntiAFK()
    antiAFKRunning = false
    if antiAFKConnection then antiAFKConnection:Disconnect() end
    AntiAFKBtn.Text = "Anti AFK: OFF"
    AntiAFKBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
end

-- ==================== DELETE WALLS ====================
local function SecureCall(func)
    pcall(function() task.spawn(func) end)
end

local function CanDelete(obj)
    if not obj or not obj.Parent then return false end
    if obj:IsA("Terrain") then return false end
    if obj.Name == "Baseplate" then return false end
    if obj.Size.X > 200 and obj.Size.Z > 200 and obj.Position.Y < 10 then return false end
    if obj.Size.X > 300 and obj.Size.Z > 300 then return false end
    if obj.Position.Y < -40 then return false end

    local char = obj:FindFirstAncestorWhichIsA("Model")
    if char and Players:GetPlayerFromCharacter(char) then return false end

    return obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation")
end

local function CreateHighlight()
    if highlight then highlight:Destroy() end
    highlight = Instance.new("SelectionBox")
    highlight.LineThickness = 0.05
    highlight.Color3 = Color3.fromRGB(255, 60, 60)
    highlight.Transparency = 0.4
    highlight.Parent = game:GetService("CoreGui")
end

RunService.RenderStepped:Connect(function()
    if not deleteMode then
        if highlight then highlight.Adornee = nil end
        return
    end
    local target = mouse.Target
    if target and CanDelete(target) then
        if not highlight then CreateHighlight() end
        highlight.Adornee = target
    else
        if highlight then highlight.Adornee = nil end
    end
end)

mouse.Button1Down:Connect(function()
    if not deleteMode then return end
    if not (UserInputService:IsKeyDown(Enum.KeyCode.LeftAlt) or UserInputService:IsKeyDown(Enum.KeyCode.RightAlt)) then return end

    local target = mouse.Target
    if target and CanDelete(target) then
        SecureCall(function()
            table.insert(deletedObjects, {
                object = target, parent = target.Parent, cframe = target.CFrame,
                size = target.Size, color = target.Color, transparency = target.Transparency,
                cancollide = target.CanCollide, anchored = target.Anchored
            })
            target.Parent = nil
            RestoreBtn.Text = "Restablecer (" .. #deletedObjects .. ")"
        end)
    end
end)

DeleteBtn.MouseButton1Click:Connect(function()
    deleteMode = not deleteMode
    DeleteBtn.Text = "Delete Walls: " .. (deleteMode and "ON" or "OFF")
    DeleteBtn.BackgroundColor3 = deleteMode and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(50, 50, 55)
end)

AntiAFKBtn.MouseButton1Click:Connect(function()
    if antiAFKRunning then
        StopAntiAFK()
    else
        StartAntiAFK()
    end
end)

RestoreBtn.MouseButton1Click:Connect(function()
    if #deletedObjects > 0 then
        local last = table.remove(deletedObjects)
        if last and last.object then
            SecureCall(function()
                last.object.Parent = last.parent
                last.object.CFrame = last.cframe
                last.object.Size = last.size
                last.object.Color = last.color
                last.object.Transparency = last.transparency
                last.object.CanCollide = last.cancollide
                last.object.Anchored = last.anchored
            end)
        end
        RestoreBtn.Text = "Restablecer (" .. #deletedObjects .. ")"
    end
end)
